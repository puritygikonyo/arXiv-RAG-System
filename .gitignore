# =============================================================================
# .gitignore — arXiv RAG System
# =============================================================================

# ── Environment & secrets (NEVER commit these) ───────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.uv/

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# ── Linting ───────────────────────────────────────────────────────────────────
.ruff_cache/

# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── Docker ────────────────────────────────────────────────────────────────────
# Keep docker-compose.yml but ignore overrides
docker-compose.override.yml

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite3
alembic/versions/*.pyc

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── OS generated ─────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Data & Models (too large for git) ────────────────────────────────────────
data/
models/
*.bin
*.safetensors

# ── Airflow (local) ───────────────────────────────────────────────────────────
airflow/logs/
airflow/plugins/
airflow.cfg
airflow.db
