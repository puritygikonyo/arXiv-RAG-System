# =============================================================================
# arXiv RAG System — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. It is already in .gitignore.
# Every variable is documented below with its phase, type, and default.
# =============================================================================


# =============================================================================
# PHASE 1 — APP CORE
# =============================================================================

# Application environment: "development" | "staging" | "production"
APP_ENV=development

# Log level: "DEBUG" | "INFO" | "WARNING" | "ERROR"
LOG_LEVEL=INFO

# Secret key for signing tokens (generate with: openssl rand -hex 32)
SECRET_KEY=changeme-generate-a-real-secret-in-production

# Allowed CORS origins (comma-separated). Use * for local dev only.
CORS_ORIGINS=http://localhost:3000,http://localhost:7860


# =============================================================================
# PHASE 2 — FASTAPI
# =============================================================================

# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# API rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=60


# =============================================================================
# PHASE 3 — POSTGRESQL (Neon.tech free tier)
# =============================================================================
# Sign up free at: https://neon.tech
# Your connection string is shown in the Neon dashboard after creating a project.

# Full async-compatible connection string
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/arxiv_rag

# Connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30


# =============================================================================
# PHASE 4 — ARXIV PIPELINE (Airflow via Astronomer Astro free tier)
# =============================================================================
# Sign up free at: https://www.astronomer.io/try-astro/

# arXiv API base URL (no key needed — it's free and open)
ARXIV_API_BASE_URL=http://export.arxiv.org/api/query

# Categories to fetch (comma-separated arXiv category codes)
# See full list: https://arxiv.org/category_taxonomy
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL,cs.IR

# Max papers to fetch per DAG run (keep low to avoid rate limits)
ARXIV_MAX_RESULTS_PER_RUN=100

# Airflow connection ID (set in Astronomer Astro UI, not here)
# AIRFLOW_CONN_POSTGRES_DEFAULT is set in the Astro UI secrets manager


# =============================================================================
# PHASE 5 & 6 — OPENSEARCH (single Docker node for local dev)
# =============================================================================

OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=admin
OPENSEARCH_USE_SSL=false

# Index names (don't change unless you know why)
OPENSEARCH_PAPERS_INDEX=arxiv_papers
OPENSEARCH_CHUNKS_INDEX=arxiv_chunks

# BM25 search settings
SEARCH_MAX_RESULTS=20
SEARCH_MIN_SCORE=0.1

# Hybrid search RRF (Reciprocal Rank Fusion) weight
# 0.0 = pure BM25, 1.0 = pure vector, 0.5 = equal blend
HYBRID_SEARCH_VECTOR_WEIGHT=0.5


# =============================================================================
# PHASE 6 — EMBEDDINGS (Jina AI free tier)
# =============================================================================
# Sign up free at: https://jina.ai — 1M tokens included
# Dashboard: https://cloud.jina.ai

JINA_API_KEY=your-jina-api-key-here
JINA_EMBEDDING_MODEL=jina-embeddings-v3
JINA_EMBEDDING_DIMENSIONS=1024

# Chunking strategy
CHUNK_SIZE=512
CHUNK_OVERLAP=50


# =============================================================================
# PHASE 7 — LLM (Groq free tier — fastest inference for open models)
# =============================================================================
# Sign up free at: https://console.groq.com
# Free tier: generous rate limits, llama3 + mixtral available

GROQ_API_KEY=your-groq-api-key-here

# Model to use. Options: llama3-8b-8192 | llama3-70b-8192 | mixtral-8x7b-32768
LLM_MODEL=llama-3.3-70b-versatile

# Generation settings
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_STREAMING=true

# Agentic RAG settings
AGENT_MAX_RETRIEVAL_ATTEMPTS=3
AGENT_RELEVANCE_THRESHOLD=0.7


# =============================================================================
# PHASE 8 — REDIS CACHE (Upstash free tier)
# =============================================================================
# Sign up free at: https://upstash.com
# Free tier: 10,000 commands/day, 256MB storage

# Redis connection URL from Upstash dashboard
REDIS_URL=redis://localhost:6379

# Cache TTL in seconds (default: 1 hour)
CACHE_TTL_SECONDS=3600

# Semantic cache similarity threshold (0.0 to 1.0)
# Queries with similarity > threshold reuse cached response
CACHE_SIMILARITY_THRESHOLD=0.92


# =============================================================================
# PHASE 8 — LANGFUSE MONITORING (free cloud tier)
# =============================================================================
# Sign up free at: https://cloud.langfuse.com
# Create a project → Settings → API Keys

LANGFUSE_PUBLIC_KEY=your-langfuse-public-key-here
LANGFUSE_SECRET_KEY=your-langfuse-secret-key-here
LANGFUSE_HOST=https://cloud.langfuse.com


# =============================================================================
# PHASE 9 — TELEGRAM BOT
# =============================================================================
# Create a bot: message @BotFather on Telegram → /newbot
# Copy the token it gives you here

TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Optional: restrict bot to specific chat IDs (comma-separated)
# Leave empty to allow all users
TELEGRAM_ALLOWED_CHAT_IDS=


# =============================================================================
# PHASE 10 — HUGGING FACE SPACES DEPLOYMENT
# =============================================================================
# These are set as Secrets in the HF Spaces UI — not in this file for prod.
# Keep them here for reference only.

# HF_TOKEN=your-huggingface-write-token
# SPACE_ID=your-username/arxiv-rag-system
